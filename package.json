{
  "name": "weblio-site",
  "version": "1.0.0",
  "private": true,
  "description": "Weblio website with backend APIs for contact and analytics",
  "main": "backend/server.js",
  "scripts": {
    "start": "npm run frontend:build && node backend/server.js",
    "dev": "node backend/server.js",
    "frontend:dev": "vite --config frontend/vite.config.cjs",
    "frontend:build": "vite build --config frontend/vite.config.cjs",
    "build": "npm run frontend:build",
    "test": "vitest run"
  },
  "dependencies": {
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "vite": "^5.4.19",
    "vitest": "^2.1.8"
  }
}